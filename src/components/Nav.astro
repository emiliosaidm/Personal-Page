---
const base = import.meta.env.BASE_URL;
---

<header
	class="sticky top-0 z-50 border-b border-white/5 bg-[#07070c]/75 backdrop-blur-md"
>
	<nav
		class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-6 py-4"
		aria-label="Principal"
	>
		<a
			href={`${base}`}
			class="font-display text-sm font-semibold tracking-tight text-white transition hover:text-teal-300"
		>
			Emilio Said
		</a>
		<ul class="flex items-center gap-6 text-sm text-zinc-400">
			<li>
				<a href="#sobre" class="transition hover:text-white">Sobre mí</a>
			</li>
			<li>
				<a href="#proyectos" class="transition hover:text-white">Proyectos</a>
			</li>
			<li>
				<a
					href="https://github.com/emiliosaidm"
					class="transition hover:text-white"
					target="_blank"
					rel="noopener noreferrer">GitHub</a
				>
			</li>
		</ul>
	</nav>
</header>
