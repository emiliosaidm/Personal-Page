---
import { withBase, pathWithinBase } from '../utils/paths';
import MobileNav from './react/MobileNav';

const pathname = Astro.url.pathname;
const within = pathWithinBase(pathname);

const links = [
	{ href: withBase(''), label: 'Home', path: '/' },
	{ href: withBase('about/'), label: 'About', path: '/about' },
	{ href: withBase('work/'), label: 'Work', path: '/work' },
	{ href: withBase('projects/'), label: 'Projects', path: '/projects' },
	{
		href: withBase('open-source/'),
		label: 'Open source',
		path: '/open-source',
	},
	{ href: withBase('contact/'), label: 'Contact', path: '/contact' },
];

function isActive(path: string) {
	const w = within.replace(/\/$/, '') || '/';
	const p = path.replace(/\/$/, '') || '/';
	if (p === '/') return w === '/' || w === '';
	return w === p || w.startsWith(`${p}/`);
}
---

<header
	class="sticky top-0 z-50 border-b border-white/[0.06] bg-[#050508]/80 backdrop-blur-xl"
>
	<div
		class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-5 py-4 md:px-8"
	>
		<a
			href={withBase('')}
			class="group flex shrink-0 items-center gap-3"
			data-astro-prefetch
		>
			<span
				class="flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-cyan-400/25 to-fuchsia-500/20 text-xs font-bold tracking-tighter text-white ring-1 ring-white/10"
				>ES</span
			>
			<div class="hidden leading-tight sm:block">
				<span class="block text-sm font-semibold text-white">Emilio Said</span>
				<span
					class="block font-mono text-[10px] font-medium uppercase tracking-[0.14em] text-zinc-500"
					>Maccise</span
				>
			</div>
		</a>

		<nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
			{
				links.map(({ href, label, path: route }) => (
					<a
						href={href}
						data-astro-prefetch
						class:list={[
							'rounded-full px-3.5 py-1.5 text-sm font-medium transition',
							isActive(route)
								? 'bg-white/10 text-white'
								: 'text-zinc-400 hover:bg-white/5 hover:text-zinc-100',
						]}
					>
						{label}
					</a>
				))
			}
		</nav>

		<div class="flex items-center gap-3">
			<a
				href="https://github.com/emiliosaidm"
				target="_blank"
				rel="noopener noreferrer"
				class="hidden rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 font-mono text-xs font-medium text-zinc-300 transition hover:border-white/20 hover:text-white sm:inline-flex"
			>
				GitHub
			</a>
			<MobileNav client:idle links={links} within={within} />
		</div>
	</div>
</header>
