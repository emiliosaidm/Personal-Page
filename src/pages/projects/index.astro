---
import Layout from '../../layouts/Layout.astro';
import { startupProjects } from '../../data/startups';
import { profile } from '../../data/profile';
import { withBase } from '../../utils/paths';

const title = `Projects — ${profile.name}`;
const description =
	'Meefi, Meefi Analytics, Ventrauren, and UI kit work — stacks from ~/startups.';
---

<Layout {title} {description}>
	<div class="mx-auto max-w-6xl px-5 pb-24 pt-12 md:px-8 md:pt-16">
		<p class="font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-violet-400/90">
			Projects
		</p>
		<h1
			class="mt-3 max-w-3xl font-display text-4xl font-extrabold tracking-tight text-white md:text-5xl"
		>
			Startups folder, decomposed.
		</h1>
		<p class="mt-4 max-w-3xl text-lg text-zinc-400">
			Each card is grounded in the actual tree on disk (paths shown) plus README
			/ dependency metadata where it materially changes the story — especially
			for Meefi Analytics’ CFDI tooling and Meefi’s multi-environment ops.
		</p>

		<div class="mt-16 space-y-16">
			{
				startupProjects.map((p, i) => (
					<article
						class="scroll-mt-28 rounded-3xl border border-white/[0.08] bg-gradient-to-b from-white/[0.04] to-transparent p-6 md:p-10"
						id={p.slug}
					>
						<div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
							<div>
								<span class="font-mono text-xs text-zinc-500">
									{String(i + 1).padStart(2, '0')}
								</span>
								<h2 class="mt-2 font-display text-2xl font-bold text-white md:text-3xl">
									{p.name}
								</h2>
								<p class="mt-1 text-sm font-medium text-cyan-300/90">{p.role}</p>
								<p class="mt-1 font-mono text-xs text-zinc-500">{p.localPath}</p>
							</div>
							{p.link ? (
								<a
									href={p.link}
									target="_blank"
									rel="noopener noreferrer"
									class="inline-flex shrink-0 items-center justify-center rounded-full border border-cyan-500/40 bg-cyan-500/10 px-5 py-2 text-sm font-semibold text-cyan-200 transition hover:bg-cyan-500/20"
								>
									Open product
								</a>
							) : null}
						</div>
						<p class="mt-6 max-w-3xl text-base leading-relaxed text-zinc-300">
							{p.summary}
						</p>
						<ul class="mt-6 space-y-3 max-w-3xl">
							{p.highlights.map((h) => (
								<li class="flex gap-3 text-sm leading-relaxed text-zinc-400">
									<span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-gradient-to-br from-cyan-400 to-fuchsia-500" />
									<span>{h}</span>
								</li>
							))}
						</ul>
						<div class="mt-8 flex flex-wrap gap-2">
							{p.stack.map((t) => (
								<span class="rounded-full border border-white/10 bg-black/40 px-3 py-1 font-mono text-[11px] text-zinc-300">
									{t}
								</span>
							))}
						</div>
					</article>
				))
			}
		</div>

		<p class="mt-16 text-center text-sm text-zinc-500">
			Want the coursework side?
			<a
				href={withBase('open-source/')}
				class="ml-1 text-cyan-400 underline-offset-4 hover:underline"
				data-astro-prefetch>See open source</a
			>.
		</p>
	</div>
</Layout>
