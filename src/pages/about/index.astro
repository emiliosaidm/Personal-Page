---
import Layout from '../../layouts/Layout.astro';
import { profile } from '../../data/profile';
import { withBase } from '../../utils/paths';

const title = `About — ${profile.name}`;
const description = profile.narrative[0];
---

<Layout {title} {description}>
	<div class="mx-auto max-w-6xl px-5 pb-20 pt-12 md:px-8 md:pt-16">
		<p class="font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-cyan-400/90">
			About
		</p>
		<h1
			class="mt-3 max-w-3xl font-display text-4xl font-extrabold tracking-tight text-white md:text-5xl"
		>
			Who I am, what I optimize for, and where I’m headed.
		</h1>
		<p class="mt-4 max-w-2xl text-lg text-zinc-400">{profile.githubBio}</p>

		<div class="mt-16 space-y-10 max-w-3xl">
			{
				profile.narrative.map((p) => (
					<p class="text-base leading-relaxed text-zinc-300 md:text-lg">{p}</p>
				))
			}
		</div>

		<section class="mt-20" aria-labelledby="focus-heading">
			<h2
				id="focus-heading"
				class="font-display text-2xl font-bold text-white md:text-3xl"
			>
				Focus areas
			</h2>
			<div class="mt-8 grid gap-5 md:grid-cols-3">
				{
					profile.focusAreas.map((f) => (
						<div class="rounded-2xl border border-white/[0.08] bg-white/[0.03] p-5">
							<h3 class="font-display text-lg font-semibold text-white">{f.title}</h3>
							<p class="mt-3 text-sm leading-relaxed text-zinc-400">{f.body}</p>
						</div>
					))
				}
			</div>
		</section>

		<section class="mt-20" aria-labelledby="edu-heading">
			<h2
				id="edu-heading"
				class="font-display text-2xl font-bold text-white md:text-3xl"
			>
				Education
			</h2>
			<ul class="mt-8 space-y-6">
				{
					profile.education.map((e) => (
						<li class="rounded-2xl border border-white/[0.08] bg-black/30 p-6 md:flex md:gap-10">
							<div class="shrink-0 md:w-48">
								<p class="font-mono text-xs uppercase tracking-wider text-fuchsia-400/90">
									{e.institution}
								</p>
								<p class="mt-1 text-sm font-semibold text-white">{e.role}</p>
							</div>
							<p class="mt-4 text-sm leading-relaxed text-zinc-400 md:mt-0 md:text-base">
								{e.detail}
							</p>
						</li>
					))
				}
			</ul>
		</section>

		<div class="mt-16 flex flex-wrap gap-4">
			<a
				href={withBase('work/')}
				class="rounded-full bg-white/10 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-white/15"
				data-astro-prefetch>View work timeline</a
			>
			<a
				href={withBase('projects/')}
				class="rounded-full border border-white/15 px-5 py-2.5 text-sm font-medium text-zinc-200 transition hover:border-white/25"
				data-astro-prefetch>Startup portfolio</a
			>
		</div>
	</div>
</Layout>
