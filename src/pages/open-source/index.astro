---
import Layout from '../../layouts/Layout.astro';
import { repoHighlights } from '../../data/githubHighlights';
import { profile } from '../../data/profile';
import { withBase } from '../../utils/paths';

const title = `Open source — ${profile.name}`;
const description =
	'Curated GitHub repositories: coursework, Rails history, docs, and data experiments.';
---

<Layout {title} {description}>
	<div class="mx-auto max-w-6xl px-5 pb-24 pt-12 md:px-8 md:pt-16">
		<p class="font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-teal-400/90">
			Open source
		</p>
		<h1
			class="mt-3 max-w-3xl font-display text-4xl font-extrabold tracking-tight text-white md:text-5xl"
		>
			GitHub, intentionally curated.
		</h1>
		<p class="mt-4 max-w-3xl text-lg text-zinc-400">
			These entries are hand-picked from the public GitHub API (repository names,
			descriptions, and primary languages). They skew toward what defines this
			trajectory today: data coursework at ITAM, Rails foundations from Le Wagon,
			and smaller math / CS exercises.
		</p>

		<div class="mt-12 overflow-hidden rounded-2xl border border-white/[0.08]">
			<table class="w-full text-left text-sm">
				<thead
					class="border-b border-white/[0.08] bg-white/[0.03] font-mono text-[10px] uppercase tracking-wider text-zinc-500"
				>
					<tr>
						<th class="px-4 py-3 md:px-6">Repository</th>
						<th class="hidden px-4 py-3 md:table-cell md:px-6">Language</th>
						<th class="px-4 py-3 md:px-6">Intent</th>
					</tr>
				</thead>
				<tbody class="divide-y divide-white/[0.06]">
					{
						repoHighlights.map((r) => (
							<tr class="transition hover:bg-white/[0.02]">
								<td class="px-4 py-4 align-top md:px-6">
									<a
										href={r.url}
										target="_blank"
										rel="noopener noreferrer"
										class="font-mono text-sm font-semibold text-cyan-300 hover:text-cyan-200"
									>
										{r.name}
									</a>
								</td>
								<td class="hidden px-4 py-4 align-top font-mono text-xs text-zinc-500 md:table-cell md:px-6">
									{r.language ?? '—'}
								</td>
								<td class="px-4 py-4 align-top text-zinc-400 md:px-6">
									{r.description}
								</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>

		<p class="mt-10 text-sm text-zinc-500">
			Full list (20 public repositories as of last API check) lives on
			<a
				href="https://github.com/emiliosaidm?tab=repositories"
				class="text-cyan-400 hover:underline"
				target="_blank"
				rel="noopener noreferrer">github.com/emiliosaidm</a
			>. This table can be generated at build time from the API if you want full
			automation later.
		</p>

		<div class="mt-12 flex flex-wrap gap-4">
			<a
				href={withBase('projects/')}
				class="rounded-full border border-white/15 px-5 py-2.5 text-sm font-medium text-zinc-200 transition hover:border-white/25"
				data-astro-prefetch>← Back to startup write-ups</a
			>
		</div>
	</div>
</Layout>
