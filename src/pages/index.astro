---
import Layout from '../layouts/Layout.astro';
import HeroHome from '../components/react/HeroHome';
import { profile } from '../data/profile';
import { withBase } from '../utils/paths';
import { startupProjects } from '../data/startups';

const title = `${profile.name} — Applied math, data & product`;
const description = `${profile.shortTitle}. ${profile.githubBio}`;
---

<Layout {title} {description}>
	<HeroHome
		client:load
		name={profile.name}
		shortTitle={profile.shortTitle}
		location={profile.location}
		avatar={profile.avatar}
		taglines={profile.taglines}
		githubBio={profile.githubBio}
		publicRepos={profile.githubMeta.publicRepos}
		sinceYear={profile.githubMeta.sinceYear}
		links={profile.links}
	/>

	<section
		class="mx-auto max-w-6xl border-t border-white/[0.06] px-5 py-16 md:px-8 md:py-24"
		aria-labelledby="explore-heading"
	>
		<div class="mb-10 max-w-2xl">
			<h2
				id="explore-heading"
				class="font-display text-2xl font-bold tracking-tight text-white md:text-3xl"
			>
				Map of the site
			</h2>
			<p class="mt-3 text-zinc-400">
				Each section is intentionally dense: real stacks, real repos, and how
				the pieces connect — not a generic landing template.
			</p>
		</div>

		<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
			<a
				href={withBase('about/')}
				data-astro-prefetch
				class="group flex flex-col rounded-2xl border border-white/[0.08] bg-gradient-to-br from-white/[0.06] to-transparent p-6 transition hover:border-cyan-500/30 hover:shadow-lg hover:shadow-cyan-500/5"
			>
				<span class="font-mono text-[10px] font-semibold uppercase tracking-widest text-cyan-400/90"
					>01</span
				>
				<h3
					class="mt-3 font-display text-lg font-semibold text-white group-hover:text-cyan-100"
				>
					About
				</h3>
				<p class="mt-2 flex-1 text-sm leading-relaxed text-zinc-400">
					Story, motivations, ITAM + Le Wagon context, and the focus areas I
					optimize for.
				</p>
				<span
					class="mt-4 font-mono text-xs text-zinc-500 transition group-hover:text-cyan-400/80"
					>Read →</span
				>
			</a>

			<a
				href={withBase('work/')}
				data-astro-prefetch
				class="group flex flex-col rounded-2xl border border-white/[0.08] bg-gradient-to-br from-white/[0.06] to-transparent p-6 transition hover:border-fuchsia-500/30 hover:shadow-lg hover:shadow-fuchsia-500/5"
			>
				<span class="font-mono text-[10px] font-semibold uppercase tracking-widest text-fuchsia-400/90"
					>02</span
				>
				<h3
					class="mt-3 font-display text-lg font-semibold text-white group-hover:text-fuchsia-100"
				>
					Work timeline
				</h3>
				<p class="mt-2 flex-1 text-sm leading-relaxed text-zinc-400">
					Meefi, analytics services, ITAM coursework, and bootcamp foundations —
					chronological with tags.
				</p>
				<span
					class="mt-4 font-mono text-xs text-zinc-500 transition group-hover:text-fuchsia-400/80"
					>Timeline →</span
				>
			</a>

			<a
				href={withBase('projects/')}
				data-astro-prefetch
				class="group flex flex-col rounded-2xl border border-white/[0.08] bg-gradient-to-br from-white/[0.06] to-transparent p-6 transition hover:border-violet-500/30 hover:shadow-lg hover:shadow-violet-500/5 md:col-span-2 lg:col-span-1"
			>
				<span class="font-mono text-[10px] font-semibold uppercase tracking-widest text-violet-400/90"
					>03</span
				>
				<h3
					class="mt-3 font-display text-lg font-semibold text-white group-hover:text-violet-100"
				>
					Startups folder
				</h3>
				<p class="mt-2 flex-1 text-sm leading-relaxed text-zinc-400">
					Deep dives on Meefi, Meefi Analytics, Ventrauren, and the shadcn
					dashboard kit — stacks copied from your local trees.
				</p>
				<span
					class="mt-4 font-mono text-xs text-zinc-500 transition group-hover:text-violet-400/80"
					>Deep dive →</span
				>
			</a>

			<a
				href={withBase('open-source/')}
				data-astro-prefetch
				class="group flex flex-col rounded-2xl border border-white/[0.08] bg-gradient-to-br from-white/[0.06] to-transparent p-6 transition hover:border-teal-500/30 hover:shadow-lg hover:shadow-teal-500/5 lg:col-span-2"
			>
				<span class="font-mono text-[10px] font-semibold uppercase tracking-widest text-teal-400/90"
					>04</span
				>
				<h3
					class="mt-3 font-display text-lg font-semibold text-white group-hover:text-teal-100"
				>
					Open source & coursework
				</h3>
				<p class="mt-2 flex-1 text-sm leading-relaxed text-zinc-400">
					Curated GitHub highlights: FDD notebooks, docs site, Rails history,
					structures homework, and more — each with language + intent.
				</p>
				<span
					class="mt-4 font-mono text-xs text-zinc-500 transition group-hover:text-teal-400/80"
					>Browse repos →</span
				>
			</a>

			<a
				href={withBase('contact/')}
				data-astro-prefetch
				class="group flex flex-col rounded-2xl border border-white/[0.08] bg-gradient-to-br from-cyan-500/10 via-transparent to-fuchsia-500/10 p-6 transition hover:border-white/20"
			>
				<span class="font-mono text-[10px] font-semibold uppercase tracking-widest text-zinc-400"
					>05</span
				>
				<h3 class="mt-3 font-display text-lg font-semibold text-white">Contact</h3>
				<p class="mt-2 flex-1 text-sm leading-relaxed text-zinc-400">
					Best channels for collaboration, recruiting, or data projects.
				</p>
				<span class="mt-4 font-mono text-xs text-zinc-500 transition group-hover:text-white"
					>Let’s talk →</span
				>
			</a>
		</div>
	</section>

	<section
		class="mx-auto max-w-6xl border-t border-white/[0.06] px-5 py-16 md:px-8 md:py-20"
		aria-labelledby="meefi-heading"
	>
		<h2
			id="meefi-heading"
			class="font-display text-xl font-bold text-white md:text-2xl"
		>
			Flagship: Meefi
		</h2>
		<p class="mt-3 max-w-3xl text-zinc-400">
			{startupProjects[0].summary}
		</p>
		<ul class="mt-6 flex flex-wrap gap-2">
			{
				startupProjects[0].stack.map((t) => (
					<li class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 font-mono text-xs text-zinc-300">
						{t}
					</li>
				))
			}
		</ul>
		<a
			href={withBase('projects/')}
			class="mt-8 inline-flex items-center gap-2 font-mono text-sm font-medium text-cyan-400 transition hover:text-cyan-300"
			data-astro-prefetch
		>
			Full write-up under Projects <span aria-hidden>→</span>
		</a>
	</section>
</Layout>
