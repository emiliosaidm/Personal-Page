---
import '../styles/global.css';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { withBase } from '../utils/paths';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Emilio Said Maccise',
	description =
		'Applied mathematics & data science — product engineering at Meefi, Mexico City.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const iconHref = withBase('favicon.svg');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#07070c" />
		<link rel="canonical" href={canonical} />
		<link rel="icon" type="image/svg+xml" href={iconHref} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Sora:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body
		class="font-display mesh-bg min-h-screen bg-[#050508] text-zinc-200 antialiased selection:bg-cyan-400/20 selection:text-cyan-50"
	>
		<div
			class="pointer-events-none fixed inset-0 -z-10 overflow-hidden"
			aria-hidden="true"
		>
			<div
				class="animate-gradient-blob absolute -left-1/4 top-0 h-[min(85vw,560px)] w-[min(85vw,560px)] rounded-full bg-cyan-500/12 blur-[110px]"
			>
			</div>
			<div
				class="animate-gradient-blob absolute -right-1/4 top-1/3 h-[min(75vw,480px)] w-[min(75vw,480px)] rounded-full bg-fuchsia-600/10 blur-[110px] [animation-delay:-7s]"
			>
			</div>
			<div
				class="animate-gradient-blob absolute bottom-0 left-1/3 h-[min(60vw,400px)] w-[min(60vw,400px)] rounded-full bg-violet-600/10 blur-[100px] [animation-delay:-12s]"
			>
			</div>
			<div
				class="animate-pulse-glow absolute left-1/2 top-[22%] h-px w-[min(92%,800px)] -translate-x-1/2 bg-gradient-to-r from-transparent via-cyan-400/35 to-transparent"
			>
			</div>
		</div>
		<SiteNav />
		<main>
			<slot />
		</main>
		<SiteFooter />
	</body>
</html>
