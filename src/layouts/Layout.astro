---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Emilio Said Maccise',
	description =
		'Matemáticas aplicadas, datos y producto — Meefi, Ciudad de México.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const iconHref = `${import.meta.env.BASE_URL}favicon.svg`;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		<link rel="icon" type="image/svg+xml" href={iconHref} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Sora:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body
		class="font-display min-h-screen bg-[#07070c] text-zinc-200 antialiased selection:bg-teal-400/25 selection:text-teal-50"
	>
		<div
			class="pointer-events-none fixed inset-0 -z-10 overflow-hidden"
			aria-hidden="true"
		>
			<div
				class="animate-gradient-blob absolute -left-1/4 top-0 h-[min(80vw,520px)] w-[min(80vw,520px)] rounded-full bg-teal-500/15 blur-[100px]"
			>
			</div>
			<div
				class="animate-gradient-blob absolute -right-1/4 bottom-0 h-[min(70vw,480px)] w-[min(70vw,480px)] rounded-full bg-violet-500/12 blur-[100px] [animation-delay:-6s]"
			>
			</div>
			<div
				class="animate-pulse-glow absolute left-1/2 top-1/3 h-px w-[min(90%,720px)] -translate-x-1/2 bg-gradient-to-r from-transparent via-teal-400/40 to-transparent"
			>
			</div>
		</div>
		<slot />
	</body>
</html>
